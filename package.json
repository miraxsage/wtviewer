{
  "name": "wtviewer_init",
  "version": "0.1.0",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "concurrently --kill-others \"next dev -p 3456\" \"wait-on http://localhost:3456 && electron .\"",
    "build": "next build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "dist": "npm run build && npm run build:electron && electron-builder",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "jszip": "^3.10.1",
    "next": "16.1.6",
    "node-unrar-js": "^2.0.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-virtuoso": "^4.18.3",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
